---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  /** Identifies which page this is, for motion/page-init.ts's astro:page-load
   * dispatch (rendered as document.body.dataset.page) — see that file's
   * header comment for why dispatch-by-identity replaces each page having
   * its own re-runnable <script>. */
  page: "home" | "about" | "work";
}

const { title = "Bakehouse", page } = Astro.props;

// Static (pre-JS / reduced-motion) clip-path, expressed with the same CSS
// tokens that octagon.ts reads at runtime — both sources resolve identically.
// calc(0% + var(X)) simplifies to var(X); calc(100% - var(X)) stays as-is.
const staticClipPath = [
  "polygon(",
  "  var(--mat-safe-inset-x)               var(--mat-safe-inset-top),",
  "  66%                                   var(--mat-safe-inset-top),",
  "  calc(100% - var(--mat-safe-inset-x))  var(--mat-safe-inset-top),",
  "  calc(100% - var(--mat-safe-inset-x))  50%,",
  "  calc(100% - var(--mat-safe-inset-x))  calc(100% - var(--mat-safe-inset-bottom)),",
  "  33%                                   calc(100% - var(--mat-safe-inset-bottom)),",
  "  var(--mat-safe-inset-x)               calc(100% - var(--mat-safe-inset-bottom)),",
  "  var(--mat-safe-inset-x)               50%",
  ")",
].join("\n");
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="https://use.typekit.net/edz5xyo.css" />
    <!-- Jost (variable, --font-sans): normal weights only, no ital axis —
         requesting italics merged with a normal weight range hits a Google
         Fonts bug (google/fonts #2445) where the italics silently fail to
         render. We don't use italics on font-sans; if ever needed, request
         them as a separate family line, not merged into this one.
         Range is 200..600 (ExtraLight–SemiBold): a weight requested outside
         a variable face's declared range clamps to the nearest in-range
         value rather than erroring — confirmed the 400..600 range from
         Story 19.2 was silently rendering font-light (300, the timeline
         years) as Regular. Widened to include the lighter end actually
         used, not just Regular/Medium. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@200..600&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body data-page={page}>
    <!--
      Three layers, back to front:
        1. Background  — the body itself (--color-background, white)
        2. Midground   — the ambient mat div (--color-mat, tan)
        3. Foreground  — chapter papers via <slot />
    -->

    <!-- Layer 2: Midground.
         Full-bleed fixed div (inset: 0). The visible margins come entirely
         from vertex homes being inset by the --mat-safe-inset-* tokens — not
         from the div's own position. clip-path: polygon() defines the visible
         area; octagon.ts rewrites it every frame. To change margins, edit the
         tokens in global.css; don't touch this element. -->
    <div
      id="midground-mat"
      class="fixed inset-0 z-10"
      style={`background: var(--color-mat); clip-path: ${staticClipPath};`}
      aria-hidden="true"
      transition:persist="mat"
    >
    </div>

    <!-- Ambient layers slot — for fixed decorative layers (e.g. ScrollShapes)
         that must live at the root stacking context, not inside the foreground
         stage. Use slot="ambient" on the component in the page file. -->
    <slot name="ambient" />

    <!-- Layer 3: Foreground stage — full-screen canvas, no layout opinion.
         pointer-events-none here so the transparent area of the stage doesn't
         block the nav. Chapter.astro restores pointer-events-auto on each paper.
         opacity-0: page-transitions.ts fades this in on every load (cold or
         in-app) as part of the enter sequence — baked in here, not set via
         gsap.fromTo's immediateRender, so there's no flash of full-opacity
         content before the fade starts (confirmed by sampling computed
         opacity during a cold load: fromTo's immediate-render was snapping
         it from a briefly-visible 1 down to 0 rather than starting there).
         The <noscript> fallback below is what keeps this from being
         permanently invisible if JS never runs. -->
    <div
      class="foreground-stage fixed inset-0 z-30 pointer-events-none opacity-0"
    >
      <slot />
    </div>
    <noscript>
      <style>
        .foreground-stage {
          opacity: 1 !important;
        }
      </style>
    </noscript>

    <Nav />

    <!-- Logo: fixed top-left, tracks the mat's visible left edge.
         .logo-backdrop rotates the paper zone; the img stays upright above it.
         To tune: edit the inset/rotate values in .logo-backdrop and the
         poke/blur values in .logo-shadow-wrap / .logo-shadow-shape below. -->
    <a
      href="/"
      class="logo fixed z-40 top-0 left-0"
      aria-label="Bakehouse"
      transition:persist="logo"
    >
      <div class="logo-backdrop">
        <div class="logo-shadow-wrap">
          <div class="logo-shadow-shape"></div>
        </div>
        <div class="logo-paper"></div>
      </div>
      <img src="/logo.svg" alt="Bakehouse" />
    </a>
  </body>
</html>

<style>
  .logo {
    display: inline-block;
    isolation: isolate;
  }

  /* Rotating paper zone — extends past the img by the padding values.
     top/left/right/bottom = how far the paper overhangs the logo on each side.
     rotate() = tilt angle (positive = clockwise). */
  .logo-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: -30px;
    bottom: -6px;
    transform: rotate(0.5deg);
  }

  /* Blur wrapper — extends past the backdrop by the shadow poke amounts.
     right/bottom here are relative to .logo-backdrop's edges. */
  .logo-shadow-wrap {
    position: absolute;
    inset: 0;
    right: -6px; /* poke-x: shadow juts this far past paper's right edge */
    bottom: -6px; /* poke-y: shadow juts this far past paper's bottom edge */
    filter: blur(4px);
    z-index: 0;
  }

  /* Clipped trapezoid: three sides inset, lower-right corner pokes out.
     First  px value = shadow inset from paper's left/top/bottom edges. */
  .logo-shadow-shape {
    width: 100%;
    height: 100%;
    clip-path: polygon(
      12px 12px,
      calc(100% - 14px) 10px,
      100% 100%,
      1px calc(100% - 12px)
    );
    background: var(--paper-shadow-color);
    opacity: 0.25;
  }

  /* White card — fills the backdrop, above the shadow. */
  .logo-paper {
    position: absolute;
    inset: 0;
    background: var(--color-foreground);
    z-index: 1;
  }

  /* Logo image — upright, above the tilted paper.
     margin controls breathing room between the logo and the paper edges. */
  .logo img {
    position: relative;
    z-index: 2;
    display: block;
    width: 306px;
    height: auto;
    margin: 14px 0 10px 10px; /* top right bottom left */
  }
</style>

<script>
  import { initOctagonWobble, octagonController } from "../motion/octagon";
  import { initPageTransitions } from "../motion/page-transitions";
  import {
    initHomePage,
    initAboutPage,
    initWorkPage,
  } from "../motion/page-init";
  initOctagonWobble();
  initPageTransitions();

  // Dispatches to the current page's own bootstrapping on every load, cold
  // or SPA — see page-init.ts's header comment for why this replaces each
  // page having its own <script data-astro-rerun>.
  document.addEventListener("astro:page-load", () => {
    const page = document.body.dataset.page;
    if (page === "home") initHomePage();
    else if (page === "about") initAboutPage();
    else if (page === "work") initWorkPage();
  });

  if (import.meta.env.DEV) {
    // Console/devtool access, mirroring __beatModel — e.g.
    // __octagonController.expandToEdges(350)
    (window as any).__octagonController = octagonController;
  }
</script>
