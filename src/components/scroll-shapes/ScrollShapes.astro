---
/**
 * ScrollShapes — ambient decorative layer.
 *
 * Renders a fixed full-screen container between the mat (z-20) and the chapter
 * papers (z-30). Shapes are generated and animated at runtime by motion.ts.
 *
 * Visibility is driven entirely by scroll position, not page-script moments:
 * each shape has a scrollY at which it enters from below, and moves as a pure
 * function of scrollY from there. See docs/scroll-shapes.md for the full model.
 *
 * This component renders only the container + its config (as a data-config
 * JSON attribute) — the actual initScrollShapes() call lives in
 * global-scripts/page-init.ts's initHomePage(), not a script here. A same-page
 * <script data-astro-rerun> (needed so a repeat visit re-initializes this
 * component's non-persisted container) cannot use imports at all — Astro's
 * compiler forces any inline script with an extra attribute into
 * unprocessed is:inline treatment, and explicitly rejects combining
 * data-astro-rerun with `src` on the same tag. See global-scripts/page-init.ts's header
 * comment for the full reasoning; this component just reads a config prop
 * and renders a div — remove the import from a page (and the matching
 * initScrollShapes call from that page's global-scripts/page-init.ts function) and it's
 * gone with no other residue.
 */
import type { ScrollShapesConfig } from "./config";
import { defaultConfig } from "./config";

interface Props {
  config?: Partial<ScrollShapesConfig>;
}

const { config = {} } = Astro.props;
const resolvedConfig: ScrollShapesConfig = { ...defaultConfig, ...config };
---

<div
  data-el="scroll-shapes"
  data-config={JSON.stringify(resolvedConfig)}
  aria-hidden="true"
  class="scroll-shapes-layer"
>
</div>

<style>
  .scroll-shapes-layer {
    position: fixed;
    inset: 0;
    z-index: var(--z-shapes);
    pointer-events: none;
    /* Nested multiply, two distinct jobs:
       - Child level (motion.ts sets mix-blend-multiply on each shape div):
         blends overlapping shapes with EACH OTHER, so two overlapping shapes
         read as compounded-darker than either alone, not just flat-stacked.
       - Container level (this rule): blends the resulting flattened shape
         group, as a whole, against the mat OUTSIDE this stacking context.
       Both are required, and neither substitutes for the other: this
       container's own position+z-index already establish a stacking context,
       and a stacking context is a blending-isolation boundary — a shape's
       own mix-blend-mode can only ever reach backdrop within its nearest
       containing stacking context (i.e. sibling shapes), never the mat
       beyond it. Only the container's own mix-blend-mode reaches past that
       boundary to blend the whole layer with what's behind it. */
    mix-blend-mode: multiply;
  }
</style>
