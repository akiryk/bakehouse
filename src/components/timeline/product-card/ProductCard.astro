---
// ProductCard — a project thumbnail + title + description, revealed by the
// timeline chapter's stopTimelineAt()/reveal mechanism (components/timeline/motion-script.ts).
//
// Deliberately does NOT own its own on-screen position — the caller wraps it
// in its own positioning element (currently: Content.astro's .tl-card-anchor
// div). That positioning MUST live on a wrapper, not on this component's own
// root element: the reveal mechanism animates this element's `y` via GSAP,
// and GSAP fights with a CSS percentage transform (like the centering
// translateY(-50%) .tl-card-anchor needs) on the *same* element — it mostly
// preserves the % correctly, but at some viewport sizes it silently resolves
// the whole transform to flat pixels and drops the -50% entirely, snapping
// the card to its top edge instead of centering it. Confirmed via a real
// bug: large-size cards, which are tall enough to make the misplacement
// obvious, went top-aligned at 1512×824 and 1728×1000 despite the exact same
// CSS working at 1440×900. Keeping the static transform off this component
// entirely sidesteps the interaction regardless of GSAP's internal heuristics.
//
// data-overlay is the id the reveal mechanism targets directly (see
// RevealSpec in components/timeline/motion-script.ts) — pass the caller's own unique id via the
// dataOverlay prop, e.g. the project's year.
export type ProductCardSize = "small" | "medium" | "large";

interface Props {
  image: string;
  title: string;
  description: string;
  size: ProductCardSize;
  dataOverlay: string;
  /** Defaults to `title` — most project images don't need distinct alt text. */
  alt?: string;
}

const {
  image,
  title,
  description,
  size,
  dataOverlay,
  alt = title,
} = Astro.props;

// Tailwind's scanner needs literal class strings somewhere in the source —
// a template-interpolated name (`w-(--timeline-card-width-${size})`) isn't
// reliably picked up, since Tailwind scans source text, not runtime values.
// A lookup whose VALUES are the literal strings keeps all three visible to
// the scanner regardless of which one is chosen at runtime.
const widthClass: Record<ProductCardSize, string> = {
  small: "w-(--timeline-card-width-small)",
  medium: "w-(--timeline-card-width-medium)",
  large: "w-(--timeline-card-width-large)",
};
---

<figure
  class:list={["tl-card", "m-0 bg-white opacity-0", widthClass[size]]}
  data-overlay={dataOverlay}
>
  <img src={image} alt={alt} class="tl-thumb w-full block p-4" />
  <figcaption class="bg-slate-light pt-1 px-4 pb-2">
    <h3
      class="font-sans font-bold mt-3 text-sm uppercase text-caption tracking-widest"
    >
      {title}
    </h3>
    <p class="font-sans m-0 mb-2 text-caption text-lg">{description}</p>
  </figcaption>
</figure>

<style>
  /* Asymmetric padding — bottom 1.2rem vs 1rem top/sides is an intentional
     visual weight decision below the thumbnail.
     box-shadow is a specific designer value, not a standard Tailwind shadow token. */
  .tl-card {
    padding: 0;
    box-shadow: var(--shadow-card);
  }

  /* 3/2 aspect ratio — no Tailwind token (aspect-video = 16/9). object-fit
     keeps a real image from distorting to fill that box (the placeholder
     this replaced was a plain gradient div with no intrinsic size to
     preserve). */
  .tl-thumb {
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }
</style>
