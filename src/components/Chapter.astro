---
// Chapter.astro — the foreground "paper" wrapper.
// header and footer slots are optional; main is always rendered.
// The data-chapter attribute is used by the scroll engine.
//
// Layering model (no negative z-index, no overflow:hidden):
//   .chapter-paper         — shadow stage: position:relative, isolation:isolate
//   .chapter-paper::before — the blurred shadow rectangle (z-index:0)
//   .chapter-paper-content — the crisp white card (z-index:1, above shadow)

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<article class="chapter-paper" data-chapter={id}>
  <div class="chapter-shadow-wrap">
    <div class="chapter-shadow-shape"></div>
  </div>
  <div class="chapter-paper-content">
    {
      Astro.slots.has("header") && (
        <header class="chapter-header">
          <slot name="header" />
        </header>
      )
    }
    <main class="chapter-main">
      <slot name="main" />
    </main>
    {
      Astro.slots.has("footer") && (
        <footer class="chapter-footer">
          <slot name="footer" />
        </footer>
      )
    }
  </div>
</article>

<style>
  /* Shadow stage — sizes the shadow's containing block.
     isolation:isolate creates a stacking context so ::before can sit below
     the content via z-index without going negative.
     will-change:transform promotes this layer before scroll starts so the
     fly-away (a pure transform) never triggers repaint of the blurred shadow. */
  .chapter-paper {
    position: relative;
    isolation: isolate;
    width: min(1000px, 90vw);
    will-change: transform;
  }

  /* Two-element shadow system — needed because filter:blur() is applied before
     clip-path clips the result, which would give a hard edge.
     Solution: clip the inner shape, blur the outer wrapper.
     The wrapper is oversized (extends past the card's lower-right corner by
     poke-x and poke-y) to give the blur room to spread outward.
     The inner shape's clip-path carves the trapezoid:
       upper-left:  inset from card's top-left by --paper-shadow-inset
       upper-right: card's right edge, inset from top
       lower-right: the extended corner (100% 100%)
       lower-left:  inset from left; raised from card-bottom by inset
     The left, top, and bottom polygon edges stay hidden under the card (z-index:1
     above this z-index:0 layer); only the soft lower-right corner is visible. */
  .chapter-shadow-wrap {
    position: absolute;
    top: 0;
    left: 0;
    right: calc(-1 * var(--paper-shadow-poke-x));
    bottom: calc(-1 * var(--paper-shadow-poke-y));
    filter: blur(var(--paper-shadow-blur));
    z-index: 0;
  }

  .chapter-shadow-shape {
    width: 100%;
    height: 100%;
    clip-path: polygon(
      var(--paper-shadow-inset) var(--paper-shadow-inset),
      calc(100% - var(--paper-shadow-poke-x)) var(--paper-shadow-inset),
      100% 100%,
      var(--paper-shadow-inset)
        calc(100% - var(--paper-shadow-poke-y) - var(--paper-shadow-inset))
    );
    background: var(--paper-shadow-color);
    opacity: var(--paper-shadow-opacity);
  }

  /* The crisp white card — sits above the shadow in the stacking context. */
  .chapter-paper-content {
    position: relative;
    z-index: 1;
    background-color: var(--color-foreground);
    color: var(--color-ink);
    font-family: var(--font-serif);
    min-height: 60vh;
    padding: 4rem 4rem 3rem 3rem;
  }
</style>
