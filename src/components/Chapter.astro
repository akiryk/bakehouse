---
// Chapter.astro — the neutral [data-chapter] transform target.
// Just the marker the scroll engine sequences; it knows nothing about what a
// "paper" is. Compose with Paper.astro when a chapter should render as a card.
//
// Props:
//   id — required; matched by the scroll engine via [data-chapter]
//
// pointer-events-auto is required, not decorative: Base.astro sets
// pointer-events-none on the whole .foreground-stage so its transparent
// margins don't block the nav, and this is what restores it per chapter —
// without it, a chapter's content (text, images) becomes unselectable and
// un-inspectable in DevTools, since pointer events fall through to whatever
// fixed layer sits beneath it (the midground mat) instead of ever reaching
// real content.

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<article class="chapter relative pointer-events-auto" data-chapter={id}>
  <slot />
</article>

<style>
  /* Tailwind handles: relative.
     CSS reason 1: will-change is GSAP-coordinated initial state — no Tailwind
     equivalent. This is the element the engine actually transforms, so the
     fly-away must be promoted here, not on Paper. */
  .chapter {
    will-change: transform;
  }
</style>
