---
// Chapter.astro — the foreground "paper" wrapper.
// header and footer slots are optional; main is always rendered.
// The data-chapter attribute is used by the scroll engine.
//
// Props:
//   id     — required; matched by the scroll engine via [data-chapter]
//   paper  — default true. When false, renders no white card or shadow:
//             content sits directly on the midground. Use for full-bleed chapters.
//
// Layering model (paper=true, no negative z-index, no overflow:hidden):
//   article.chapter-paper    — shadow stage: position:relative, isolation:isolate
//   .chapter-shadow-wrap     — blur wrapper (z-index:0)
//   .chapter-shadow-shape    — clipped trapezoid (inside blur wrapper)
//   .chapter-paper-content   — the crisp white card (z-index:1, above shadow)

interface Props {
  id: string;
  paper?: boolean;
}

const { id, paper = true } = Astro.props;
---

{
  paper ? (
    <article class="chapter-paper" data-chapter={id}>
      <div class="chapter-shadow-wrap">
        <div class="chapter-shadow-shape" />
      </div>
      <div class="chapter-paper-content">
        {Astro.slots.has("header") && (
          <header class="chapter-header">
            <slot name="header" />
          </header>
        )}
        <main class="chapter-main">
          <slot name="main" />
        </main>
        {Astro.slots.has("footer") && (
          <footer class="chapter-footer">
            <slot name="footer" />
          </footer>
        )}
      </div>
    </article>
  ) : (
    <article class="chapter-bare" data-chapter={id}>
      <div class="chapter-bare-content">
        {Astro.slots.has("header") && (
          <header class="chapter-header">
            <slot name="header" />
          </header>
        )}
        <main class="chapter-main">
          <slot name="main" />
        </main>
        {Astro.slots.has("footer") && (
          <footer class="chapter-footer">
            <slot name="footer" />
          </footer>
        )}
      </div>
    </article>
  )
}

<style>
  /* ── Paper variant ────────────────────────────────────────────────────────── */

  /* Shadow stage — isolation:isolate lets the shadow sit below the card
     without negative z-index. will-change:transform promotes the layer for
     scroll compositing so the fly-away never repaints the blurred shadow. */
  .chapter-paper {
    position: relative;
    isolation: isolate;
    width: min(1000px, 90vw);
    will-change: transform;
  }

  /* Two-element shadow system (blur on wrap, clip on shape) so the blur bleeds
     past the polygon edges instead of being clipped to them. */
  .chapter-shadow-wrap {
    position: absolute;
    top: 0;
    left: 0;
    right: calc(-1 * var(--paper-shadow-poke-x));
    bottom: calc(-1 * var(--paper-shadow-poke-y));
    filter: blur(var(--paper-shadow-blur));
    z-index: 0;
  }

  .chapter-shadow-shape {
    width: 100%;
    height: 100%;
    clip-path: polygon(
      var(--paper-shadow-inset) var(--paper-shadow-inset),
      calc(100% - var(--paper-shadow-poke-x)) var(--paper-shadow-inset),
      100% 100%,
      var(--paper-shadow-inset)
        calc(100% - var(--paper-shadow-poke-y) - var(--paper-shadow-inset))
    );
    background: var(--paper-shadow-color);
    opacity: var(--paper-shadow-opacity);
  }

  /* The crisp white card — sits above the shadow in the stacking context. */
  .chapter-paper-content {
    position: relative;
    z-index: 1;
    background-color: var(--color-foreground);
    color: var(--color-ink);
    font-family: var(--font-serif);
    min-height: 60vh;
    padding: 4rem 4rem 3rem 3rem;
  }

  /* ── Paperless variant ────────────────────────────────────────────────────── */

  /* No white card, no shadow. Content sits directly on the midground.
     will-change:transform keeps the fly-away (if used) composited. */
  .chapter-bare {
    position: relative;
    will-change: transform;
  }

  .chapter-bare-content {
    text-align: center;
  }
</style>
