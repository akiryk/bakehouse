---
import Chapter from "../../../components/Chapter.astro";
---

<Chapter id="intro">
  <p slot="main" class="salutation">Dear <span class="blank" aria-label="blank"></span>,</p>
</Chapter>

<style>
  .salutation {
    font-family: var(--font-serif);
    color: var(--color-ink);
    font-size: 2rem;
    font-style: italic;
    margin: 0;
    line-height: 1.3;
  }

  /*
   * A ruled blank for the recipient's name.
   * inline-block + vertical-align: bottom seats the border on the text baseline.
   * The 1.1em height gives a visible writing zone; the border is the rule itself.
   */
  .blank {
    display: inline-block;
    width: 7em;
    height: 1.1em;
    border-bottom: 1px solid var(--color-ink);
    vertical-align: bottom;
    margin-left: 0.25em;
    margin-right: 0.05em;
  }
</style>
