---
// Chapter 2 — paperless, Futura PT medium 32px, white, centered on midground.
// Two scroll beats: line A (intro), then line B (experience) with midground darken.
import Chapter from "../../../components/Chapter.astro";
import StageCenter from "../../../layouts/StageCenter.astro";
---

<StageCenter>
  <Chapter id="placeholder" paper={false}>
    <div slot="main" class="beats-container">
      <p class="beat-text" data-beat="a">
        Bakehouse Studio is Adam Kiryk, a designer and web developer.
      </p>
      <p class="beat-text" data-beat="b">
        I've been leading web design projects for several years.
      </p>
    </div>
  </Chapter>
</StageCenter>

<style>
  .beats-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* Beat elements start visible in HTML (no-JS / pre-JS fallback).
     The beats engine sets them to opacity:0 via fromTo() when it initialises,
     then scrubs them to opacity:1 as the user scrolls through the beat window.
     Reduced-motion branch jumps the timeline to progress=1 immediately. */
  .beat-text {
    font-family: var(--font-sans);
    font-size: 2rem; /* 32px */
    font-weight: 500; /* Futura PT medium */
    color: var(--color-foreground); /* white */
    margin: 0;
    text-align: center;
    max-width: 22em;
    line-height: 1.3;
  }
</style>
