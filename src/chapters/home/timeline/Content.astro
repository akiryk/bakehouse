---
// Chapter 2 — "A brief history": paperless timeline chapter.
//
// Element roles (see motion/timeline-kit.ts):
//   [data-el="intro"]    the opening text block (independent)
//   [data-el="line"]     the vertical line — viewport-tall, static once in
//   [data-el="tape"]     the year strip — enterTape / travel / stopTimelineAt
//   [data-overlay="id"]  independent content revealed at stops
//
// Years render from script.ts (NOTES/CONFIG) so there's one tweak file.
import Chapter from "../../../components/Chapter.astro";
import { CONFIG, NOTES } from "./script";

const years = Array.from(
  { length: CONFIG.lastYear - CONFIG.firstYear + 1 },
  (_, i) => CONFIG.firstYear + i,
);
---

<Chapter id="timeline" paper={false}>
  <div
    slot="main"
    class="tl-stage fixed inset-0 h-dvh font-sans text-foreground pointer-events-none"
    data-el="stage"
  >
    <!-- Intro wrapper owns vertical centering so the script can animate the inner
         block's y without fighting a centering transform. -->
    <div
      class="tl-intro-wrap absolute inset-0 flex flex-col justify-center items-start pr-8"
    >
      <!-- opacity-0: pre-hidden so the element doesn't flash before GSAP loads.
           show("intro") in the script animates it in. -->
      <header class="tl-intro opacity-0" data-el="intro">
        <h2 class="font-light">A little history.</h2>
        <p class="font-light m-0">
          I'm Adam Kiryk, a designer and web developer based in
          Durango,&nbsp;Colorado.
        </p>
      </header>
    </div>

    <!-- The line and tape are separate elements, each driven independently by the script. -->
    <div class="tl-viewport absolute inset-0 overflow-hidden">
      <!-- opacity-0: pre-hidden; show("line") reveals it. -->
      <div
        class="tl-line absolute top-0 h-full w-px bg-white/45 opacity-0 left-(--tl-line-x)"
        data-el="line"
        aria-hidden="true"
      >
      </div>
      <div
        class="tl-tape absolute inset-x-0 top-0 will-change-transform"
        data-el="tape"
      >
        {
          years.map((year) => (
            <div
              class="absolute left-0 right-0 -translate-y-1/2 flex items-center"
              data-year={year}
              style={`top:${(year - CONFIG.firstYear) * CONFIG.pitch}vh`}
            >
              <span class="tl-num font-light text-right box-border w-(--tl-line-x) text-(--color-tl-year)">
                {year}
              </span>
              <span
                class="tl-tick w-0.5 -ml-px scale-x-0 origin-left bg-(--color-tl-year-active)"
                aria-hidden="true"
              />
              {NOTES[year] && (
                <span class="tl-note font-light text-(--color-tl-note)">
                  {NOTES[year]}
                </span>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <!-- Overlays — revealed by stopTimelineAt(); positioned independently so each
         project can land in a different place and size. -->
    <div class="absolute inset-0">
      <!-- opacity-0: pre-hidden; stopTimelineAt reveal animates in. -->
      <figure
        class="tl-card tl-card--winesmarts absolute m-0 bg-white opacity-0"
        data-overlay="winesmarts"
      >
        <div class="tl-thumb tl-thumb--warm w-full" aria-hidden="true"></div>
        <figcaption>
          <h3 class="font-serif font-normal text-ink">WineSmarts</h3>
          <p class="font-serif m-0 text-caption">
            Design and branding for a game about wine knowledge.
          </p>
        </figcaption>
      </figure>

      <figure
        class="tl-card tl-card--2011 absolute m-0 bg-white opacity-0"
        data-overlay="sample-2011"
      >
        <div class="tl-thumb tl-thumb--cool w-full" aria-hidden="true"></div>
        <figcaption>
          <h3 class="font-serif font-normal text-ink">Placeholder project</h3>
          <p class="font-serif m-0 text-caption">
            Lorem ipsum dolor sit amet, consectetur adipiscing.
          </p>
        </figcaption>
      </figure>
    </div>
  </div>
</Chapter>

<style>
  /* ── Stage: CSS custom property read by timeline-kit.ts at runtime ──────────
     --tl-line-x stays local: it's chapter-specific geometry, not a shared token.
     Colors moved to global.css @theme (--color-tl-*) and referenced directly. */
  .tl-stage {
    --tl-line-x: 27%; /* line position — used by layout and JS */
  }

  /* padding-left: calc() with a CSS var; no Tailwind equivalent. */
  .tl-intro-wrap {
    padding-left: calc(var(--tl-line-x) + 2.5rem);
  }

  /* max-width in em (not rem) so the measure scales with the fluid heading size. */
  .tl-intro {
    max-width: 34em;
  }

  /* clamp() for fluid type — Tailwind has no built-in clamp() utility.
     Margin in em so the gap is relative to the heading's own font size. */
  .tl-intro h2 {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    margin: 0 0 0.6em;
  }
  .tl-intro p {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.45;
    color: var(--color-tl-body);
  }

  /* CSS mask for tape edge dissolve — Tailwind has no mask-image utility. */
  .tl-viewport {
    mask-image: linear-gradient(
      to bottom,
      transparent 6%,
      black 22%,
      black 80%,
      transparent 96%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 6%,
      black 22%,
      black 80%,
      transparent 96%
    );
  }

  /* transform: pre-positions tape off-screen (FOUC prevention); GSAP's inline
     transform overrides this the moment compile() runs. */
  .tl-tape {
    transform: translateY(300vh);
  }

  /* clamp() for fluid year numbers. padding-right is a precise visual value
     (right-aligns numbers flush to the line — not an arbitrary number, but a
     measured alignment). font-variant-numeric requires two values on one
     declaration; Tailwind's individual lining-nums / tabular-nums utilities
     would override each other rather than compose. */
  .tl-num {
    padding-right: 1.4rem;
    font-size: clamp(2rem, 3.4vw, 2.9rem);
    font-variant-numeric: lining-nums tabular-nums;
  }

  /* height in em so the tick scales proportionally with the year number size. */
  .tl-tick {
    height: 2.25em;
  }

  /* clamp() for fluid note type. padding-left spaces notes off the tick mark
     (visual alignment, not a token-expressible value). max-width in em for
     reading width that scales with type size. */
  .tl-note {
    padding-left: 1.6rem;
    font-size: clamp(1rem, 1.6vw, 1.35rem);
    max-width: 36em;
  }

  /* Asymmetric padding — bottom 1.2rem vs 1rem top/sides is an intentional
     visual weight decision below the thumbnail.
     box-shadow is a specific designer value, not a standard Tailwind shadow token. */
  .tl-card {
    padding: 1rem 1rem 1.2rem;
    box-shadow: var(--shadow-card);
  }

  /* Per-card positions: left uses calc() with --tl-line-x; width uses min()
     for responsive clamping. These are intentional per-project layout
     coordinates, not magic numbers. */
  .tl-card--winesmarts {
    left: calc(var(--tl-line-x) + 4%);
    top: 14%;
    width: min(46%, 620px);
  }
  .tl-card--2011 {
    left: calc(var(--tl-line-x) + 14%);
    top: 30%;
    width: min(34%, 460px);
  }

  /* 3/2 aspect ratio — no Tailwind token (aspect-video = 16/9). */
  .tl-thumb {
    aspect-ratio: 3 / 2;
  }

  /* Placeholder gradient thumbnails — to be replaced with real project images.
     Not tokenized because the gradients will be deleted. */
  .tl-thumb--warm {
    background:
      radial-gradient(120% 90% at 75% 20%, #e7b98a 0%, transparent 45%),
      linear-gradient(150deg, #c67a3e, #9c4a2a);
  }
  .tl-thumb--cool {
    background:
      radial-gradient(110% 85% at 30% 25%, #b9c8d2 0%, transparent 50%),
      linear-gradient(160deg, #7c93a0, #4d616d);
  }

  /* clamp() for fluid type on card headings and captions. */
  .tl-card h3 {
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    margin: 0.9rem 0 0.2rem;
  }
  .tl-card figcaption p {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
  }
</style>
