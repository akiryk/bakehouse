---
import Base from "../layouts/Base.astro";
import ScrollShapes from "../components/scroll-shapes/ScrollShapes.astro";
import { defaultConfig } from "../components/scroll-shapes/config";

// Shapes appear during chapters 1–2 only (beats 0–2 out of 17.4 total ≈ 12%).
// Tune scrollZone.end visually: increase to let shapes linger later, decrease to
// pull them back. The last shape's scrollEntry falls at zoneEnd; it will still
// take additional scroll to fully exit the top of the viewport.
const homeShapesConfig = {
  ...defaultConfig,
  scrollZone: { start: 0, end: 0.12 },
};
import IntroContent from "../chapters/home/intro/Content.astro";
import ServicesContent from "../chapters/home/services/Content.astro";
import TimelineContent from "../chapters/home/timeline/Content.astro";
---

<Base>
  <ScrollShapes config={homeShapesConfig} slot="ambient" />
  <IntroContent />
  <ServicesContent />
  <TimelineContent />
</Base>

<script>
  import { initPageEngine } from "../motion/engine";
  import { pages } from "../config/pages";
  import { PAGE } from "@motion/home.script";
  import introMotion from "../chapters/home/intro/motion";
  import servicesMotion from "../chapters/home/services/motion";
  import timelineMotion from "../chapters/home/timeline/motion";

  const model = initPageEngine(pages.home, PAGE, [
    introMotion,
    servicesMotion,
    timelineMotion,
  ]);

  if (import.meta.env.DEV && model) {
    // Expose for console inspection: __beatModel.chapters[1].schedule
    (window as any).__beatModel = model;
    // Page schedule accessible via __beatModel.pageSchedule
    import("../dev/beat-ruler").then(({ initBeatRuler }) =>
      initBeatRuler(model),
    );
  }
</script>
