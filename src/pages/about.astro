---
import Base from "../layouts/Base.astro";
import AboutContent from "../chapters/home/about/Content.astro";
---

<Base title="Bakehouse — About">
  <AboutContent />
</Base>

<script>
  import { initPageEngine } from "../motion/engine";
  import { pages } from "../config/pages";
  import { PAGE } from "@motion/about.script";
  import aboutMotion from "../chapters/home/about/motion";

  const model = initPageEngine(pages.about, PAGE, [aboutMotion]);

  if (import.meta.env.DEV && model) {
    (window as any).__beatModel = model;
    import("../dev/beat-ruler").then(({ initBeatRuler }) =>
      initBeatRuler(model),
    );
  }
</script>
