---
// Chapter 2 — "A brief history": paperless timeline chapter.
//
// Element roles (see motion/components/timeline/motion-script.ts):
//   [data-el="intro"]    the opening text block (independent)
//   [data-el="line"]     the vertical line — viewport-tall, static once in
//   [data-el="tape"]     the year strip — enterTape / travel / stopTimelineAt
//   [data-overlay="id"]  independent content revealed at stops
//
// Years render from script.ts's CONFIG (geometry). Project overlays render
// from timeline-content.ts's PROJECTS — one ProductCard per entry, sharing
// a single on-screen anchor (see .tl-card-anchor below) nudged per-project
// via dx/dy.
//
// .tl-stage is pointer-events-auto, not -none — this is a bare Chapter with
// no <Paper>, so unlike the paper chapters there's no card to opt pointer
// events back in on. See Chapter.astro's header comment for the full
// mechanism this guards against.
import Chapter from "@components/Chapter.astro";
import ProductCard from "@components/timeline/product-card/ProductCard.astro";
import { CONFIG } from "./script";
import { PROJECTS } from "./timeline-content";

const years = Array.from(
  { length: CONFIG.lastYear - CONFIG.firstYear + 1 },
  (_, i) => CONFIG.firstYear + i,
);
---

<Chapter id="timeline">
  <div
    class="tl-stage fixed inset-0 h-dvh font-sans text-foreground pointer-events-auto"
    data-el="stage"
  >
    <!-- Intro wrapper owns vertical centering so the script can animate the inner
         block's y without fighting a centering transform. -->
    <div
      class="tl-intro-wrap absolute inset-0 flex flex-col justify-center items-start pr-8"
    >
      <!-- opacity-0: pre-hidden so the element doesn't flash before GSAP loads.
           show("intro") in the script animates it in. -->
      <header class="tl-intro opacity-0" data-el="intro">
        <h2 class="font-medium text-2xl mb-6">A little history.</h2>
        <p class="font-light m-0 text-tl-body text-2xl leading-normal">
          I'm Adam Kiryk, a designer and web developer based in
          Durango,&nbsp;Colorado.
        </p>
      </header>
    </div>

    <!-- The line and tape are separate elements, each driven independently by the script. -->
    <div class="tl-viewport absolute inset-0 overflow-hidden">
      <!-- opacity-0: pre-hidden; show("line") reveals it. -->
      <div
        class="tl-line absolute top-0 h-full w-px bg-tl-year-active/45 opacity-0 left-(--tl-line-x)"
        data-el="line"
        aria-hidden="true"
      >
      </div>
      <div
        class="tl-tape absolute inset-x-0 top-0 will-change-transform"
        data-el="tape"
      >
        {
          years.map((year) => (
            <div
              class="absolute left-0 right-0 -translate-y-1/2 flex items-center"
              data-year={year}
              style={`top:${(year - CONFIG.firstYear) * CONFIG.pitch}vh`}
            >
              <span class="tl-num font-thin text-right box-border w-(--tl-line-x) text-tl-year lining-nums tabular-nums">
                {year}
              </span>
              <span
                class="tl-tick w-0.5 -ml-px scale-x-0 origin-left bg-tl-year-active"
                aria-hidden="true"
              />
            </div>
          ))
        }
      </div>
    </div>

    <!-- Overlays — revealed by stopTimelineAt(); every card shares one
         on-screen anchor (.tl-card-anchor below) since no two are ever
         visible at the same time (see script.ts) — width (size prop) and
         a small dx/dy nudge (--tl-card-dx/--tl-card-dy, read by that same
         CSS rule) are what vary card to card. The anchor lives on this
         wrapper div, not on ProductCard itself — see global.css's
         .tl-card-anchor comment for why that split matters (GSAP animates
         the card's own `y`; a static centering transform can't safely
         share that element). -->
    <div class="absolute inset-0">
      {
        PROJECTS.map((project) => (
          <div
            class="tl-card-anchor"
            style={`--tl-card-dx: ${project.dx ?? 0}vw; --tl-card-dy: ${project.dy ?? 0}vw;`}
          >
            <ProductCard
              image={project.image}
              title={project.title}
              description={project.description}
              size={project.size}
              dataOverlay={String(project.year)}
            />
          </div>
        ))
      }
    </div>
  </div>
</Chapter>

<style>
  /* ── Stage: CSS custom property read by components/timeline/motion-script.ts at runtime ──────────
     --tl-line-x stays local: it's chapter-specific geometry, not a shared token.
     Colors moved to global.css @theme (--color-tl-*) and referenced directly. */
  .tl-stage {
    --tl-line-x: 27%; /* line position — used by layout and JS */
  }

  /* padding-left: calc() with a CSS var; no Tailwind equivalent. */
  .tl-intro-wrap {
    padding-left: calc(var(--tl-line-x) + 2.5rem);
  }

  /* max-width in em so the measure scales with .tl-intro's own font-size. */
  .tl-intro {
    max-width: 34em;
  }

  /* CSS mask for tape edge dissolve — Tailwind has no mask-image utility. */
  .tl-viewport {
    mask-image: linear-gradient(
      to bottom,
      transparent 6%,
      black 22%,
      black 80%,
      transparent 96%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 6%,
      black 22%,
      black 80%,
      transparent 96%
    );
  }

  /* transform: pre-positions tape off-screen (FOUC prevention); GSAP's inline
     transform overrides this the moment compile() runs. */
  .tl-tape {
    transform: translateY(300vh);
  }

  /* clamp() for fluid year numbers. padding-right is a precise visual value
     (right-aligns numbers flush to the line — not an arbitrary number, but a
     measured alignment). font-variant-numeric is on the element as Tailwind's
     lining-nums/tabular-nums utilities instead (they compose via --tw-numeric-*
     vars, same mechanism as v3 — no conflict). */
  .tl-num {
    padding-right: 1.4rem;
    font-size: clamp(2rem, 3.4vw, 2.9rem);
  }

  /* height in em so the tick scales proportionally with the year number size. */
  .tl-tick {
    height: 2.25em;
  }

  /* .tl-card-anchor (shared position for every project card) lives in
     global.css, not here — it's applied to a class on ProductCard.astro's
     own rendered <figure>, a different component's scope, and an
     Astro <style> block only auto-scopes to elements the OWNING component
     itself renders. Defining it here compiled without error but never
     actually matched anything on screen (confirmed: the card was falling
     back to the browser default for an unpositioned absolute element).
     See global.css's own comment for the fix and the reasoning. */
</style>
