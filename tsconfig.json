{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@docs/*": ["./docs/*"],
      "@src/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@global-scripts/*": ["./src/global-scripts/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@styles/*": ["./src/styles/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
