{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@docs/*": ["./docs/*"],
      "@src/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@chapters/*": ["./src/chapters/*"],
      "@components/*": ["./src/components/*"],
      "@config/*": ["./src/config/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@motion/*": ["./src/motion/*"],
      "@pages/*": ["./src/pages/*"],
      "@styles/*": ["./src/styles/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
